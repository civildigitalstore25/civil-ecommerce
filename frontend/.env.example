# --- Canonical site (required for production) ---
# No trailing slash. Used in <link rel="canonical">, og:url, and sitemap.xml <loc> values.
# Must match the hostname you use in Google Search Console (www vs non-www).
VITE_PUBLIC_SITE_URL=https://softzcart.com

# --- API (local dev vs production) ---
# Local: http://localhost:5000
# Production build (Vercel): must be reachable during `npm run build` so the sitemap includes products + blogs.
VITE_API_BASE_URL=http://localhost:5000

# Optional (already in your stack)
# VITE_GA_MEASUREMENT_ID=
# VITE_CLARITY_PROJECT_ID=
